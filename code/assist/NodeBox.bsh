		}
		return this;
	}

	isRemoved() {
		return isRemoved;
	}

	isShown() {
		return isShown;
	}

	setDefault() {
		setColor(DEFAULT_STROKE_WIDTH, DEFAULT_STROKE_COLOR, DEFAULT_COLOR);
	}

	setDefaultColor(int strokeWidth, int strokeColor, int fillColor) {
		DEFAULT_COLOR = fillColor;
		DEFAULT_STROKE_COLOR = strokeColor;
		DEFAULT_STROKE_WIDTH = strokeWidth;
		setDefault();
	}

	active() {
		reset() {
			setDefault();
		}
		return this;
	}



	showInfo() {
		infoToast = InfoToast(node, nodeContext, overlayType);
	}

	removeInfo() {
		if (infoToast != null) infoToast.remove();
	}

	showDialog() {
		infoDialog = InfoDialog(node, nodeContext, overlayType);
	}

	removeDialog() {
		if (infoDialog != null) infoDialog.remove();
	}

	hide() {
		view.setVisibility(View.GONE);
		removeInfo();
	}

	unhide() {
		view.setVisibility(View.VISIBLE);
	}

	reset() {
		unhide();
		setDefault();
		removeInfo();
		removeDialog();
	}

	setGestureListener(This eventListener) {
		simpleGesture = SimpleGesture(view, eventListener, new Object[] { this });
		simpleGesture.listen();
	}

	view.addOnAttachStateChangeListener(new View.OnAttachStateChangeListener() {
		public void onViewAttachedToWindow(View v) {
			isRemoved = false;
			isShown = true;
			a11Y.addOverlay(TOP);
		}

		public void onViewDetachedFromWindow(View v) {
			isRemoved = true;
			isShown = false;
			a11Y.removeOverlay(TOP);
		}
	});

	getWindowManager() {
		if (WINDOW_MANAGER == null) WINDOW_MANAGER = nodeContext.getSystemService(Context.WINDOW_SERVICE);
		return WINDOW_MANAGER;
	}

	show() {
		getWindowManager().addView(view, params);
	}

	addViewTo(FrameLayout frameLayout) {
		frameLayout.addView(view, frameParams);
	}

	// Only with WindowManager
	remove(WindowManager win) {
		if (!isRemoved) {
			win.removeView(view);
		}
		removeInfo();
	}

	remove() {
		if (!isRemoved) {
			getWindowManager().removeView(view);
		}
		removeInfo();
		removeDialog();
	}
	setTouchable(boolean toucable) {
		// Retrieve the current params directly from the view
		WindowManager.LayoutParams currentParams = (WindowManager.LayoutParams) view.getLayoutParams();
		if (currentParams == null) {
			currentParams = params;
		}

		if (toucable) {
			currentParams.flags &= ~WindowManager.LayoutParams.FLAG_NOT_TOUCHABLE;
		} else {
			currentParams.flags |= WindowManager.LayoutParams.FLAG_NOT_TOUCHABLE;
		}

		params = currentParams;
		if (isShown && !isRemoved) {
			getWindowManager().updateViewLayout(view, params);
		}
	}
	setDefault();

	post(Runnable postRun) {
		Handler mainHandler = new Handler(Looper.getMainLooper());
		mainHandler.post(postRun);
	}
	
	return this;
}

NodeBox(AccessibilityNodeInfo node) {
	Context nodeContext = tasker.getAccessibilityService();
	int overlayType = WindowManager.LayoutParams.TYPE_ACCESSIBILITY_OVERLAY;
	return NodeBox(nodeContext, overlayType, node);

