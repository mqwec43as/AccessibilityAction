NodeBox(Context nodeContext, int overlayType, AccessibilityNodeInfo node) {
	final This TOP = this;
	This a11Y = tasker.getJavaVariable("a11Y");
	setAlpha(int color, int alpha) {
		return (alpha << 24) | (color & 0x00ffffff);
	}
	boolean useA11y = WindowManager.LayoutParams.TYPE_ACCESSIBILITY_OVERLAY == overlayType ? true : false;
	Runnable displayOverlay;

	int getStatusBarHeight() {
		int result = 0;
		int resourceId = context.getResources().getIdentifier("status_bar_height", "dimen", "android");
		if (resourceId > 0) result = context.getResources().getDimensionPixelSize(resourceId);
		if (useA11y) {
			if (a11Y.useA11yOffset) {
				return result;
			} else {
				return 0;
			}
		} else {
			if (a11Y.useOffset) {
				return result;
			} else {
				return 0;
			}
		}
