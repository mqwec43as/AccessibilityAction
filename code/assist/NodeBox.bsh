	WindowManager WINDOW_MANAGER;
	boolean isRemoved;
	boolean isShown;
	int DEFAULT_COLOR = Color.TRANSPARENT;
	int DEFAULT_STROKE_COLOR = setAlpha(Color.GREEN, 100);
	int DEFAULT_STROKE_WIDTH = 1;
	This infoToast;
	This infoDialog;
	This simpleGesture;

	if (this.caller.nodeBoxColor != void) DEFAULT_COLOR = this.caller.nodeBoxColor;
	if (this.caller.nodeBoxStrokeColor != void) DEFAULT_STROKE_COLOR = this.caller.nodeBoxStrokeColor;
	if (this.caller.nodeBoxStrokeWidth != void) DEFAULT_STROKE_WIDTH = this.caller.nodeBoxStrokeWidth;



	View view = new View(nodeContext);
	Rect bounds = new Rect();
	WindowManager.LayoutParams params;
	FrameLayout.LayoutParams frameParams;

	updateParams() {
		node.refresh();
		node.getBoundsInScreen(bounds);
		params = new WindowManager.LayoutParams(
			bounds.width(),
			bounds.height(),
			overlayType,
			WindowManager.LayoutParams.FLAG_NOT_FOCUSABLE,
			PixelFormat.TRANSLUCENT
		);
		params.gravity = Gravity.TOP | Gravity.LEFT;
		params.x = bounds.left;
		params.y = bounds.top - getStatusBarHeight();

		frameParams = new FrameLayout.LayoutParams(bounds.width(), bounds.height());
		frameParams.leftMargin = bounds.left;
		frameParams.topMargin = bounds.top - getStatusBarHeight();
	}

	updateParams();

	setColor(int strokeWidth, int strokeColor, int fillColor) {
		GradientDrawable activeFill = new GradientDrawable();
		activeFill.setColor(fillColor);
		activeFill.setStroke(strokeWidth, strokeColor);
		view.setBackgroundDrawable(activeFill);
		reset() {
